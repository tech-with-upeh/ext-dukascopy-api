{
  "compilerOptions": {
    /* other options like "target", "module", "outDir", etc. */
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    // Add "node" to the types array
    "types": ["node"]
  },
  "include": ["server.ts"]
}
